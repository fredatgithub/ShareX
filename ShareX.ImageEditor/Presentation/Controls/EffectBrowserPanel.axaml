<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:ShareX.ImageEditor.Presentation.Controls"
             xmlns:theming="using:ShareX.ImageEditor.Presentation.Theming"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="600"
             x:Class="ShareX.ImageEditor.Presentation.Controls.EffectBrowserPanel">
    <Grid RowDefinitions="Auto,*">
        <!-- Search Box -->
        <TextBox x:Name="SearchBox"
                 Grid.Row="0"
                 Classes="effect-search"
                 PlaceholderText="Search image effects..."
                 Margin="16,16,16,0"
                 CornerRadius="4"
                 VerticalContentAlignment="Center"
                 TextChanged="OnSearchTextChanged"/>

        <!-- Categories List -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="CategoriesControl" Margin="16,8,16,16">
                <ItemsControl.DataTemplates>
                    <!-- EffectCategory Template -->
                    <DataTemplate DataType="{x:Type controls:EffectCategory}" x:DataType="controls:EffectCategory">
                        <StackPanel Margin="0,0,0,8" IsVisible="{Binding IsVisible}">
                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6" Margin="8,8,0,8">
                                <TextBlock Text="{Binding HeaderText}" Classes="category-header" Margin="0"/>
                                <Border Classes="category-tip"
                                        Grid.Column="1"
                                        IsVisible="{Binding HasHeaderHint}"
                                        ToolTip.Tip="{Binding HeaderHint}">
                                    <TextBlock Text="{x:Static theming:LucideIcons.lightbulb}"
                                               Classes="category-tip-icon"/>
                                </Border>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding VisibleEffects}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type controls:EffectItem}" x:DataType="controls:EffectItem">
                                        <Button Classes="effect-item" 
                                                Command="{Binding ExecuteCommand}"
                                                PointerPressed="OnEffectItemPointerPressed"
                                                ToolTip.Tip="{Binding Description}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Icon}" 
                                                           FontFamily="{DynamicResource ShareX.FontFamily.Icon}"
                                                           FontWeight="Normal"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource ShareX.Brush.Text}"
                                                           VerticalAlignment="Center"
                                                           Width="20" TextAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" 
                                                           Foreground="{DynamicResource ShareX.Brush.Text}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.DataTemplates>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
