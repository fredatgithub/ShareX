<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ShareX.ImageEditor.Presentation.ViewModels"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="200"
             x:Class="ShareX.ImageEditor.Presentation.Views.UrlInputDialogView"
             x:DataType="vm:UrlInputDialogViewModel">

    <Border Background="{DynamicResource ShareX.Brush.Background.Popup}"
            BorderBrush="{DynamicResource ShareX.Brush.Border}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="0"
            Width="450"
            BoxShadow="0 4 10 0 #40000000">
        <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource ShareX.Brush.Background.Popup}">
            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource ShareX.Brush.Background.Toolbar}"
                    BorderBrush="{DynamicResource ShareX.Brush.Border}" BorderThickness="0,0,0,1"
                    Padding="10,6">
                <TextBlock Text="Load image from URL" FontWeight="Normal"/>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20" Spacing="8">
                <TextBlock Text="Image URL:" FontWeight="Normal"/>
                <TextBox Text="{Binding Url, Mode=TwoWay}"
                         PlaceholderText="https://example.com/image.png"
                         IsEnabled="{Binding !IsLoading}"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E04040"
                           FontWeight="Normal"
                           FontSize="12"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}"
                             Height="4"
                             Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="{DynamicResource ShareX.Brush.Background.Toolbar}"
                    BorderBrush="{DynamicResource ShareX.Brush.Border}" BorderThickness="0,1,0,0"
                    Padding="10">
                <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
                    <Button Classes="editor-button" Padding="20,0" Content="OK" Command="{Binding OkCommand}" HorizontalContentAlignment="Center"/>
                    <Button Classes="editor-button" Padding="20,0" Content="Cancel" Command="{Binding CancelCommand}" HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
