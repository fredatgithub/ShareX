<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ShareX.ImageEditor.Presentation.ViewModels"
        xmlns:views="using:ShareX.ImageEditor.Presentation.Views"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="ShareX.ImageEditor.Presentation.Views.EditorWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding WindowTitle}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <views:EditorView Name="EditorViewControl"/>

</Window>