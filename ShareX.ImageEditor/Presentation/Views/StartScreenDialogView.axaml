<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ShareX.ImageEditor.Presentation.ViewModels"
             xmlns:theming="clr-namespace:ShareX.ImageEditor.Presentation.Theming"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="500"
             x:Class="ShareX.ImageEditor.Presentation.Views.StartScreenDialogView"
             x:DataType="vm:StartScreenDialogViewModel">

    <Border Background="{DynamicResource ShareX.Brush.Background.Toolbar}"
            BorderBrush="{DynamicResource ShareX.Brush.Border}"
            BorderThickness="1"
            Width="250"
            CornerRadius="4"
            Padding="4"
            BoxShadow="0 8 24 0 #50000000">
        <Grid RowDefinitions="Auto,Auto,Auto">
            <!-- Action Buttons -->
            <StackPanel Grid.Row="1" Spacing="4">
                <Button Classes="editor-button" Command="{Binding NewImageCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="12,10" Height="42">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{x:Static theming:LucideIcons.image_plus}"
                                   FontFamily="{DynamicResource ShareX.FontFamily.Icon}"
                                   FontSize="18" FontWeight="Normal"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Create new image..." FontWeight="Normal" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="editor-button" Command="{Binding OpenFileCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="12,10" Height="42">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{x:Static theming:LucideIcons.folder_open}"
                                   FontFamily="{DynamicResource ShareX.FontFamily.Icon}"
                                   FontSize="18" FontWeight="Normal"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Open image file..." FontWeight="Normal" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="editor-button" Command="{Binding LoadFromClipboardCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="12,10" Height="42">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{x:Static theming:LucideIcons.clipboard_paste}"
                                   FontFamily="{DynamicResource ShareX.FontFamily.Icon}"
                                   FontSize="18" FontWeight="Normal"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Load image from clipboard" FontWeight="Normal" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="editor-button" Command="{Binding LoadFromUrlCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="12,10" Height="42">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{x:Static theming:LucideIcons.link}"
                                   FontFamily="{DynamicResource ShareX.FontFamily.Icon}"
                                   FontSize="18" FontWeight="Normal"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Load image from URL..." FontWeight="Normal" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="editor-button" Command="{Binding ExitCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="12,10" Height="42">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{x:Static theming:LucideIcons.log_out}"
                                   FontFamily="{DynamicResource ShareX.FontFamily.Icon}"
                                   FontSize="18" FontWeight="Normal"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Exit" FontWeight="Normal" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Recent Files -->
            <Border Grid.Row="2"
                    IsVisible="{Binding HasRecentFiles}"
                    BorderBrush="{DynamicResource ShareX.Brush.Border}" BorderThickness="0,1,0,0"
                    Margin="0,4,0,0">
                <StackPanel Margin="12,8,12,12" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,0,0,4">
                        <TextBlock Text="{x:Static theming:LucideIcons.history}"
                                   FontFamily="{DynamicResource ShareX.FontFamily.Icon}"
                                   FontSize="14" FontWeight="Normal"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"/>
                        <TextBlock Text="Recent files"
                                   FontSize="12" FontWeight="Normal"
                                   Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding RecentFiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Button Classes="editor-button"
                                        Command="{Binding $parent[ItemsControl].((vm:StartScreenDialogViewModel)DataContext).OpenRecentFileCommand}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="12,6" Height="32">
                                    <TextBlock Text="{Binding}"
                                               FontSize="12" FontWeight="Normal"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding}"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
